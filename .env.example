# Hopper Ops Environment Variables
DATABASE_URL=postgresql://hopperops:changeme@localhost:5432/hopper_ops
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.example.com/auth/google/callback
APP_URL=https://your-domain.example.com
APP_PORT=3616
ADMIN_EMAIL=your-email@example.com
SESSION_SECRET=change-me-to-a-random-string
ANTHROPIC_API_KEY=
UPTIMEROBOT_API_KEY=
SENTRY_API_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_DSN=
MONITOR_LOG_PATH=/opt/your-app/backups/monitor.log
DAILY_REPORT_LOG_PATH=/opt/your-app/backups/daily-report.log
